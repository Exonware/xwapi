CHOOSE: "CHOOSE"i
ADD_VERTEX: "ADD_VERTEX"i
DROP_VERTEX: "DROP_VERTEX"i
PAGE_RANK: "PAGE_RANK"i
PROJECT: "PROJECT"i
EXTEND: "EXTEND"i
