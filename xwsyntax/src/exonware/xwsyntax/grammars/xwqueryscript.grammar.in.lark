// Data types
INT: "INT"i | "INTEGER"i
VARCHAR: "VARCHAR"i
TEXT: "TEXT"i
FLOAT: "FLOAT"i
DOUBLE: "DOUBLE"i
DECIMAL: "DECIMAL"i
DATE: "DATE"i
DATETIME: "DATETIME"i
TIMESTAMP: "TIMESTAMP"i
BOOLEAN: "BOOLEAN"i | "BOOL"i
JSON: "JSON"i

// Boolean literals
BOOLEAN_LITERAL: "TRUE"i | "FALSE"i

// Terminals
IDENTIFIER: /[a-zA-Z_][a-zA-Z0-9_]*/
STRING: /"[^"]*"/ | /'[^']*'/
NUMBER: /\d+(\.\d+)?([eE][+-]?\d+)?/

%import common.WS
%ignore WS
%import common.CPP_COMMENT
%import common.C_COMMENT
%ignore CPP_COMMENT
%ignore C_COMMENT