VARIANCE: "VARIANCE"i
MEDIAN: "MEDIAN"i
PERCENTILE: "PERCENTILE"i
FIRST_VALUE: "FIRST_VALUE"i
LAST_VALUE: "LAST_VALUE"i
GROUP_CONCAT: "GROUP_CONCAT"i
PATH: "PATH"i
OUT: "OUT"i
IN_TRAVERSE: "IN_TRAVERSE"i
ALL_PATHS: "ALL_PATHS"i
ALL_SHORTEST_PATHS: "ALL_SHORTEST_PATHS"i
ALL_SIMPLE_PATHS: "ALL_SIMPLE_PATHS"i
BOTH: "BOTH"i
BOTHE: "BOTHE"i
BOTHV: "BOTHV"i
INE: "INE"i
INV: "INV"i
OUTE: "OUTE"i
OUTV: "OUTV"i
CLONE: "CLONE"i
CONNECTED_COMPONENTS: "CONNECTED_COMPONENTS"i
CYCLE_DETECTION: "CYCLE_DETECTION"i
CREATE_EDGE: "CREATE_EDGE"i
DELETE_EDGE: "DELETE_EDGE"i
DETACH_DELETE: "DETACH_DELETE"i
UPDATE_EDGE: "UPDATE_EDGE"i
DEGREE: "DEGREE"i
EXPAND: "EXPAND"i
EXTRACT_PATH: "EXTRACT_PATH"i
NEIGHBORS: "NEIGHBORS"i
