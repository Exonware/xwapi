@program = {{#each children}}{{value}}{{#if !@last}}
{{/if}}{{/each}}

@line = {{value}}
@stmt = {{value}}
@expr_stmt = {{value}};
@block = {
{{#each children}}{{value}}
{{/each}}}
@func_decl = function {{name}}({{params}}) {{body}}
@expr = {{value}}
@primary = {{value}}
